# Database (set automatically by Docker; override for local dev)
DATABASE_URL="file:./dev.db"

# Flipp API postal code — sets which store flyers are fetched
# Use your local postal code (Ontario examples below)
# N2B3J1 = Kitchener  |  N2A0A1 = Kitchener East  |  N0B2J0 = St. Jacobs
FLIPP_POSTAL_CODE=N2B3J1
