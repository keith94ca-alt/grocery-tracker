generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Item {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  category     String       @default("Other")
  unit         String       @default("each")
  watched      Boolean      @default(false)
  createdAt    DateTime     @default(now())
  priceEntries PriceEntry[]
  flyerNotes   FlyerNote[]
}

model Store {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  location     String?
  type         String       @default("grocery")
  createdAt    DateTime     @default(now())
  priceEntries PriceEntry[]
}

model PriceEntry {
  id        Int      @id @default(autoincrement())
  itemId    Int
  storeId   Int?
  price     Float
  quantity  Float    @default(1)
  unitPrice Float
  unit      String   @default("each")
  store     String
  source    String   @default("manual")
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  storeRef  Store?   @relation(fields: [storeId], references: [id])
}

model FlyerNote {
  id        Int      @id @default(autoincrement())
  itemId    Int
  flippId   Int      // Flipp item ID for matching
  price     Float
  unitPrice Float
  unit      String   // e.g. "per kg", "per lb", "each"
  store     String
  validFrom String
  validTo   String
  createdAt DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}
