generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  avatar       String?
  familyId     String?
  role         String    @default("member") // "admin" | "member"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  family       Family?   @relation(fields: [familyId], references: [id])

  // Personal preferences (JSON blobs)
  targetPrices String?   // JSON: { itemId: targetPrice }
  watchlist    String?   // JSON: [itemId, ...]
}

model Family {
  id              String    @id @default(cuid())
  name            String
  adminId         String
  inviteCode      String    @unique @default(cuid())
  inviteExpiresAt DateTime?
  maxMembers      Int       @default(10)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  members         User[]
}

model Item {
  id           Int          @id @default(autoincrement())
  name         String
  category     String       @default("Other")
  unit         String       @default("each")
  watched      Boolean      @default(false)
  targetPrice      Float?
  familyId         String?
  createdAt        DateTime     @default(now())
  priceEntries     PriceEntry[]
  flyerNotes       FlyerNote[]
  shoppingListItems ShoppingListItem[]

  @@unique([name, familyId])
}

model Store {
  id           Int          @id @default(autoincrement())
  name         String
  location     String?
  type         String       @default("grocery")
  familyId     String?
  createdAt    DateTime     @default(now())
  priceEntries PriceEntry[]

  @@unique([name, familyId])
}

model PriceEntry {
  id        Int      @id @default(autoincrement())
  itemId    Int
  storeId   Int?
  price     Float
  quantity  Float    @default(1)
  unitPrice Float
  unit      String   @default("each")
  store     String
  source    String   @default("manual")
  priceType String   @default("normal") // "normal" or "sale"
  date      DateTime
  notes     String?
  familyId  String?
  userId    String?
  createdAt DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  storeRef  Store?   @relation(fields: [storeId], references: [id])
}

model FlyerNote {
  id        Int      @id @default(autoincrement())
  itemId    Int
  flippId   Int      // Flipp item ID for matching
  price     Float
  unitPrice Float
  unit      String   // e.g. "per kg", "per lb", "each"
  store     String
  validFrom String
  validTo   String
  familyId  String?
  createdAt DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ShoppingListItem {
  id         Int      @id @default(autoincrement())
  name       String
  category   String   @default("Other")
  checked    Boolean  @default(false)
  priceLogged Boolean @default(false)
  price      Float?
  itemId     Int?     // FK to Item if tracked
  sortOrder  Int      @default(0)
  familyId   String?
  userId     String?
  createdAt  DateTime @default(now())

  item       Item?    @relation(fields: [itemId], references: [id])
}

model DismissedFlyerMatch {
  id            Int      @id @default(autoincrement())
  trackedItemId Int
  flippId       Int
  familyId      String?
  createdAt     DateTime @default(now())

  @@unique([trackedItemId, flippId])
}
